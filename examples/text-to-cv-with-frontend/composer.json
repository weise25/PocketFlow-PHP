{
    "name": "weise25/pocketflow-php-text-to-cv",
    "description": "Text-to-CV example for PocketFlow-PHP",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../../",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.3",
        "weise25/pocketflow-php": "@dev",
        "vlucas/phpdotenv": "^5.6",
        "dompdf/dompdf": "^3.1",
        "openai-php/client": "^0.14.0",
        "guzzlehttp/guzzle": "^7.9",
        "php-http/guzzle7-adapter": "^1.1",
        "symfony/yaml": "^7.3"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
