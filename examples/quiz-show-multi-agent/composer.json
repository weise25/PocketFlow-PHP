{
    "name": "weise25/pocketflow-php-quiz-show",
    "description": "Quiz Show Multi-Agent example for PocketFlow-PHP",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../../",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.3",
        "weise25/pocketflow-php": "@dev",
        "vlucas/phpdotenv": "^5.6",
        "openai-php/client": "^0.14.0",
        "guzzlehttp/guzzle": "^7.9"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
