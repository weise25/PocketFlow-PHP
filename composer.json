{
    "name": "weise25/pocketflow-php",
    "description": "A PHP port of the minimalist LLM framework PocketFlow.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "PocketFlow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PocketFlow\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.3",
        "react/async": "^4.0",
        "react/promise-timer": "^1.9",
        "react/promise": "^3.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.1"
    },
    "minimum-stability": "stable"
}
